DIGITRANSIT_KEY=your_api_key_here

# Oura OAuth2 (Personal Access Tokens are deprecated; use OAuth app + refresh)
OURA_ACCESS_TOKEN=your_oura_access_token_here
OURA_REFRESH_TOKEN=your_oura_refresh_token_here
OURA_CLIENT_ID=your_oura_client_id_here
OURA_CLIENT_SECRET=your_oura_client_secret_here
# Authorization must include scope: daily (sleep, readiness, cardiovascular age, etc.) and workout (cycling/running).

# Fitbit OAuth2 — all four required for automatic token refresh (e.g. on Render)
FITBIT_ACCESS_TOKEN=your_fitbit_access_token_here
FITBIT_REFRESH_TOKEN=your_fitbit_refresh_token_here
FITBIT_CLIENT_ID=your_fitbit_client_id_here
FITBIT_CLIENT_SECRET=your_fitbit_client_secret_here
